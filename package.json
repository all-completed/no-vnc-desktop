{
  "name": "no-vnc-desktop",
  "version": "1.0.0",
  "description": "Electron desktop noVNC client (WebSocket + raw TCP)",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "postinstall": "node scripts/patch-novnc.mjs",
    "dev": "node scripts/patch-novnc.mjs && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "node scripts/patch-novnc.mjs && tsc --noEmit && vite build",
    "start": "electron .",
    "pack": "npm run build && electron-builder"
  },
  "keywords": [
    "electron",
    "novnc",
    "vnc",
    "desktop"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@novnc/novnc": "^1.6.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.novncdesktop.app",
    "productName": "noVNC Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "www/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
